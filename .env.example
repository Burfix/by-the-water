# ─── Application ──────────────────────────────────────────────────────────────
# NODE_ENV values: local | development | staging | production
# "local" enables TypeORM synchronize:true (never use in staging/prod)
NODE_ENV=local
BACKEND_PORT=3001
FRONTEND_PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=compliance_user
DB_PASSWORD=CHANGE_ME
DB_NAME=compliance_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_min_64_chars_different
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS / S3-compatible Storage ──────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=compliance-audit-storage
AWS_S3_ENDPOINT=

# ─── Certificate Expiry ───────────────────────────────────────────────────────
CERT_EXPIRY_WARNING_DAYS=30
CERT_EXPIRY_CRITICAL_DAYS=7

# ─── Seed Admin (used by npm run seed only) ───────────────────────────────────
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=CHANGE_ME
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Swagger ──────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Next.js (frontend) ───────────────────────────────────────────────────────
# Local: leave as /api/v1 (proxied by Next.js rewrites)
NEXT_PUBLIC_API_URL=/api/v1
# Backend URL used by Next.js server-side proxy (NOT exposed to browser)
BACKEND_URL=http://localhost:3001
